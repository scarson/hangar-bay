# ABOUTME: Template for app/backend/docker/grafana-cloud-provisioning.env (gitignored — copy, then fill).
# ABOUTME: Dashboard-provisioning credentials, kept OUT of the Alloy container's environment (least privilege).
# Stack Grafana URL + service-account token (Editor role) for `pdm run provision-dashboards`.
# Canonical copy in 1Password ("Grafana Cloud hangar-bay-provisioner (dashboards)").
GRAFANA_STACK_URL=https://REPLACE-stack.grafana.net
GRAFANA_SA_TOKEN=REPLACE-glsa-service-account-token
