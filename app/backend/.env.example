# Environment variables for Hangar Bay Backend
# Copy this file to app/backend/src/.env and fill in your values.

ENVIRONMENT="development"
LOG_LEVEL="INFO"
# Optional: also write JSON logs to this file so Alloy can ship them to Grafana Cloud Loki.
# Dev convention: logs/backend.jsonl (relative to app/backend/, where `pdm run dev` runs;
# the Alloy container bind-mounts app/backend/logs). Leave empty to disable.
# No rotation: Loki retention is the durable store; the local file only grows.
# Truncate it freely when it gets big (`: > logs/backend.jsonl`) — Alloy
# detects truncation and re-tails from the new end.
LOG_FILE="logs/backend.jsonl"
# Explicit opt-in required for the destructive dev-only drop_all/create_all
# recreate cycle at startup. Both ENVIRONMENT=="development" AND this flag must
# be true; ENVIRONMENT defaulting to "development" (e.g. this var simply absent
# in a deploy) is never, by itself, enough to trigger the recreate.
DB_RECREATE_ON_STARTUP="true"

# Required — no default. Backend refuses to start without these.
# Credentials/db must match docker/compose.dependencies.yml (POSTGRES_USER/PASSWORD/DB).
DATABASE_URL="postgresql+asyncpg://hangar_bay_user:hangar_bay_password@localhost:5432/hangar_bay_dev"
CACHE_URL="redis://localhost:6379/0"
ESI_USER_AGENT="HangarBayApp/0.1.0 (you@example.com; local dev)"

# Test databases (pytest requires DATABASE_URL_TESTS)
DATABASE_URL_TESTS="postgresql+asyncpg://hangar_bay_user:hangar_bay_password@localhost:5432/hangar_bay_test"
CACHE_URL_TESTS="redis://localhost:6379/1"

# --- EVE SSO (M2) ---
# Register an app at https://developers.eveonline.com/applications
# Registered callback URL (dev, char-for-char; rides the Vite HTTPS proxy):
#   https://localhost:5173/api/v1/auth/sso/callback
ESI_CLIENT_ID=""
ESI_CLIENT_SECRET=""
# Token-at-rest encryption. Generate a key with (dependency-free; emits a valid Fernet key):
#   python3 -c "import base64,os; print(base64.urlsafe_b64encode(os.urandom(32)).decode())"
# (Equivalent, once `cryptography` is installed from Phase 3 on: Fernet.generate_key().)
# Comma-separate multiple keys for rotation (first = primary encrypt key).
TOKEN_CIPHER_KEYS=""

# --- M3 account features ---
# Per-user soft cap on saved searches (best-effort; enforced count-then-insert).
MAX_SAVED_SEARCHES_PER_USER=100
# Per-user soft cap on watchlist items (best-effort; enforced count-then-insert).
MAX_WATCHLIST_ITEMS_PER_USER=200
# Interval between watchlist-matcher runs (seconds; default 15 min).
WATCHLIST_MATCH_INTERVAL_SECONDS=900
# TTL on the watchlist-matcher concurrency lock (seconds).
WATCHLIST_MATCH_LOCK_TTL_SECONDS=900
# Age (days) past which read/stale watchlist notifications are pruned.
NOTIFICATION_RETENTION_DAYS=90

# --- production deployment (Render dashboard, NEVER this file) ---
# The production env contract (design spec §6). Secret VALUES live only in the Render
# dashboard (blueprint `sync: false` prompts at initial apply); connection strings come
# from blueprint fromDatabase/fromService references. Nothing below is ever committed.
#
#   ENVIRONMENT=production                  blueprint literal (defaults safe anyway — I-4)
#   DB_RECREATE_ON_STARTUP=false            blueprint literal (belt+braces with I-4)
#   LOG_LEVEL=INFO                          default
#   ESI_USER_AGENT                          dashboard secret — real contact string incl. email
#   ESI_CLIENT_ID / ESI_CLIENT_SECRET       dashboard secrets — PROD EVE app registration (never dev's)
#   ESI_SSO_CALLBACK_URL                    dashboard secret — https://<domain>/api/v1/auth/sso/callback,
#                                           char-for-char equal to the EVE portal registration
#   FRONTEND_ORIGIN                         dashboard secret — https://<domain> (same origin, I-1)
#   TOKEN_CIPHER_KEYS                       dashboard secret — FRESH Fernet key, never dev's; generate:
#                                             python3 -c "import base64,os; print(base64.urlsafe_b64encode(os.urandom(32)).decode())"
#                                           rotation = prepend-new-comma-keep-old, never drop an in-use key
#   METRICS_TOKEN                           dashboard secret — bearer token gating /metrics; generate:
#                                             python3 -c "import secrets; print(secrets.token_urlsafe(32))"
#   AGGREGATION_REGION_IDS=[10000002]       blueprint literal — JSON array string (ENV-1)
#   AGGREGATION_DEV_CONTRACT_LIMIT=0        blueprint literal — disables the silent 100-contract dev cap
#   AGGREGATION_SCHEDULER_INTERVAL_SECONDS  default (3600); /ready staleness keys off it
#   ESI_BASE_URL / ESI_TIMEOUT /
#   ESI_SSO_AUTHORIZE_URL / ESI_SSO_TOKEN_URL / ESI_SSO_JWKS_URI   defaults (pinned versions, ESI-1)
#   DATABASE_URL                            blueprint fromDatabase(connectionString) — postgresql://
#                                           normalized to postgresql+asyncpg:// by Settings
#   CACHE_URL                               blueprint fromService(keyvalue connectionString) — redis://
#   SESSION_*                               defaults
#   MAX_SAVED_SEARCHES_PER_USER / MAX_WATCHLIST_ITEMS_PER_USER /
#   WATCHLIST_MATCH_* / NOTIFICATION_RETENTION_DAYS   defaults (deliberate prod choices)
#   DATABASE_URL_TESTS / CACHE_URL_TESTS    unset in production (test-only)
