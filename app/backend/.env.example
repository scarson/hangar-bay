# Environment variables for Hangar Bay Backend
# Copy this file to app/backend/src/.env and fill in your values.

ENVIRONMENT="development"
LOG_LEVEL="INFO"

# Required — no default. Backend refuses to start without these.
DATABASE_URL="postgresql+asyncpg://user:password@localhost:5432/hangar_bay_db"
CACHE_URL="redis://localhost:6379/0"
ESI_USER_AGENT="HangarBayApp/0.1.0 (you@example.com; local dev)"

# Test databases (pytest requires DATABASE_URL_TESTS)
DATABASE_URL_TESTS="postgresql+asyncpg://user:password@localhost:5432/hangar_bay_test"
CACHE_URL_TESTS="redis://localhost:6379/1"

# --- EVE SSO (M2) ---
# Register an app at https://developers.eveonline.com/applications
# Registered callback URL (dev, char-for-char; rides the Vite HTTPS proxy):
#   https://localhost:5173/api/v1/auth/sso/callback
ESI_CLIENT_ID=""
ESI_CLIENT_SECRET=""
# Token-at-rest encryption. Generate a key with (dependency-free; emits a valid Fernet key):
#   python3 -c "import base64,os; print(base64.urlsafe_b64encode(os.urandom(32)).decode())"
# (Equivalent, once `cryptography` is installed from Phase 3 on: Fernet.generate_key().)
# Comma-separate multiple keys for rotation (first = primary encrypt key).
TOKEN_CIPHER_KEYS=""
