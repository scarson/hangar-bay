{
  "components": {
    "schemas": {
      "ContractItemSchema": {
        "description": "Schema for an item within a contract.",
        "properties": {
          "category": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Category"
          },
          "is_blueprint_copy": {
            "anyOf": [
              {
                "type": "boolean"
              },
              {
                "type": "null"
              }
            ],
            "title": "Is Blueprint Copy"
          },
          "is_included": {
            "title": "Is Included",
            "type": "boolean"
          },
          "is_singleton": {
            "title": "Is Singleton",
            "type": "boolean"
          },
          "market_group_id": {
            "anyOf": [
              {
                "type": "integer"
              },
              {
                "type": "null"
              }
            ],
            "title": "Market Group Id"
          },
          "quantity": {
            "title": "Quantity",
            "type": "integer"
          },
          "raw_quantity": {
            "anyOf": [
              {
                "type": "integer"
              },
              {
                "type": "null"
              }
            ],
            "title": "Raw Quantity"
          },
          "record_id": {
            "title": "Record Id",
            "type": "integer"
          },
          "type_id": {
            "title": "Type Id",
            "type": "integer"
          },
          "type_name": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Type Name"
          }
        },
        "required": [
          "record_id",
          "type_id",
          "quantity",
          "is_included",
          "is_singleton"
        ],
        "title": "ContractItemSchema",
        "type": "object"
      },
      "ContractSchema": {
        "description": "Schema for a public contract.",
        "properties": {
          "contract_id": {
            "title": "Contract Id",
            "type": "integer"
          },
          "date_completed": {
            "anyOf": [
              {
                "format": "date-time",
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Date Completed"
          },
          "date_expired": {
            "format": "date-time",
            "title": "Date Expired",
            "type": "string"
          },
          "date_issued": {
            "format": "date-time",
            "title": "Date Issued",
            "type": "string"
          },
          "end_location_id": {
            "anyOf": [
              {
                "type": "integer"
              },
              {
                "type": "null"
              }
            ],
            "title": "End Location Id"
          },
          "for_corporation": {
            "title": "For Corporation",
            "type": "boolean"
          },
          "is_ship_contract": {
            "title": "Is Ship Contract",
            "type": "boolean"
          },
          "issuer_corporation_id": {
            "title": "Issuer Corporation Id",
            "type": "integer"
          },
          "issuer_corporation_name": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Issuer Corporation Name"
          },
          "issuer_id": {
            "title": "Issuer Id",
            "type": "integer"
          },
          "issuer_name": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Issuer Name"
          },
          "items": {
            "default": [],
            "items": {
              "$ref": "#/components/schemas/ContractItemSchema"
            },
            "title": "Items",
            "type": "array"
          },
          "price": {
            "anyOf": [
              {
                "type": "number"
              },
              {
                "type": "null"
              }
            ],
            "title": "Price"
          },
          "reward": {
            "anyOf": [
              {
                "type": "number"
              },
              {
                "type": "null"
              }
            ],
            "title": "Reward"
          },
          "start_location_id": {
            "title": "Start Location Id",
            "type": "integer"
          },
          "start_location_name": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Start Location Name"
          },
          "status": {
            "title": "Status",
            "type": "string"
          },
          "title": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Title"
          },
          "type": {
            "title": "Type",
            "type": "string"
          },
          "volume": {
            "anyOf": [
              {
                "type": "number"
              },
              {
                "type": "null"
              }
            ],
            "title": "Volume"
          }
        },
        "required": [
          "contract_id",
          "issuer_id",
          "issuer_corporation_id",
          "start_location_id",
          "type",
          "status",
          "for_corporation",
          "date_issued",
          "date_expired",
          "is_ship_contract"
        ],
        "title": "ContractSchema",
        "type": "object"
      },
      "CurrentUserSchema": {
        "properties": {
          "character_id": {
            "title": "Character Id",
            "type": "integer"
          },
          "character_name": {
            "title": "Character Name",
            "type": "string"
          }
        },
        "required": [
          "character_id",
          "character_name"
        ],
        "title": "CurrentUserSchema",
        "type": "object"
      },
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "title": "Detail",
            "type": "array"
          }
        },
        "title": "HTTPValidationError",
        "type": "object"
      },
      "PaginatedResponse_ContractSchema_": {
        "properties": {
          "items": {
            "description": "List of items for the current page",
            "items": {
              "$ref": "#/components/schemas/ContractSchema"
            },
            "title": "Items",
            "type": "array"
          },
          "page": {
            "description": "Current page number",
            "title": "Page",
            "type": "integer"
          },
          "size": {
            "description": "Number of items per page",
            "title": "Size",
            "type": "integer"
          },
          "total": {
            "description": "Total number of items",
            "title": "Total",
            "type": "integer"
          }
        },
        "required": [
          "total",
          "page",
          "size",
          "items"
        ],
        "title": "PaginatedResponse[ContractSchema]",
        "type": "object"
      },
      "SortDirection": {
        "enum": [
          "asc",
          "desc"
        ],
        "title": "SortDirection",
        "type": "string"
      },
      "SortableContractFields": {
        "description": "Fields that can be used for sorting contracts.",
        "enum": [
          "date_issued",
          "date_expired",
          "price",
          "collateral",
          "ship_name",
          "volume"
        ],
        "title": "SortableContractFields",
        "type": "string"
      },
      "ValidationError": {
        "properties": {
          "loc": {
            "items": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "integer"
                }
              ]
            },
            "title": "Location",
            "type": "array"
          },
          "msg": {
            "title": "Message",
            "type": "string"
          },
          "type": {
            "title": "Error Type",
            "type": "string"
          }
        },
        "required": [
          "loc",
          "msg",
          "type"
        ],
        "title": "ValidationError",
        "type": "object"
      }
    }
  },
