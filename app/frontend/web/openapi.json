    "/contracts/": {
      "get": {
        "description": "Retrieves a paginated list of contracts based on specified filters.\n\nThis endpoint uses a service layer to apply advanced filtering, sorting,\nand pagination to public contracts.",
        "operationId": "list_public_contracts_contracts__get",
        "parameters": [
          {
            "description": "Case-insensitive search across contract title and ship name.",
            "in": "query",
            "name": "search",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "minLength": 3,
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "description": "Case-insensitive search across contract title and ship name.",
              "title": "Search"
            }
          },
          {
            "description": "Minimum price.",
            "in": "query",
            "name": "min_price",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "minimum": 0,
                  "type": "number"
                },
                {
                  "type": "null"
                }
              ],
              "description": "Minimum price.",
              "title": "Min Price"
            }
          },
          {
            "description": "Maximum price.",
            "in": "query",
            "name": "max_price",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "minimum": 0,
                  "type": "number"
                },
                {
                  "type": "null"
                }
              ],
              "description": "Maximum price.",
              "title": "Max Price"
            }
          },
          {
            "description": "Minimum collateral.",
            "in": "query",
            "name": "min_collateral",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "minimum": 0,
                  "type": "number"
                },
                {
                  "type": "null"
                }
              ],
              "description": "Minimum collateral.",
              "title": "Min Collateral"
            }
          },
          {
            "description": "Maximum collateral.",
            "in": "query",
            "name": "max_collateral",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "minimum": 0,
                  "type": "number"
                },
                {
                  "type": "null"
                }
              ],
              "description": "Maximum collateral.",
              "title": "Max Collateral"
            }
          },
          {
            "description": "Minimum runs for BPCs (-1 for original).",
            "in": "query",
            "name": "min_runs",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "minimum": -1,
                  "type": "integer"
                },
                {
                  "type": "null"
                }
              ],
              "description": "Minimum runs for BPCs (-1 for original).",
              "title": "Min Runs"
            }
          },
          {
            "description": "Maximum runs for BPCs.",
            "in": "query",
            "name": "max_runs",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "minimum": -1,
                  "type": "integer"
                },
                {
                  "type": "null"
                }
              ],
              "description": "Maximum runs for BPCs.",
              "title": "Max Runs"
            }
          },
          {
            "description": "Minimum Material Efficiency for BPCs. (NOT IMPLEMENTED \u2014 accepted but ignored by the service; do not expose in clients)",
            "in": "query",
            "name": "min_me",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "minimum": 0,
                  "type": "integer"
                },
                {
                  "type": "null"
                }
              ],
              "description": "Minimum Material Efficiency for BPCs. (NOT IMPLEMENTED \u2014 accepted but ignored by the service; do not expose in clients)",
              "title": "Min Me"
            }
          },
          {
            "description": "Maximum Material Efficiency for BPCs. (NOT IMPLEMENTED \u2014 accepted but ignored by the service; do not expose in clients)",
            "in": "query",
            "name": "max_me",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "minimum": 0,
                  "type": "integer"
                },
                {
                  "type": "null"
                }
              ],
              "description": "Maximum Material Efficiency for BPCs. (NOT IMPLEMENTED \u2014 accepted but ignored by the service; do not expose in clients)",
              "title": "Max Me"
            }
          },
          {
            "description": "Minimum Time Efficiency for BPCs. (NOT IMPLEMENTED \u2014 accepted but ignored by the service; do not expose in clients)",
            "in": "query",
            "name": "min_te",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "minimum": 0,
                  "type": "integer"
                },
                {
                  "type": "null"
                }
              ],
              "description": "Minimum Time Efficiency for BPCs. (NOT IMPLEMENTED \u2014 accepted but ignored by the service; do not expose in clients)",
              "title": "Min Te"
            }
          },
          {
            "description": "Maximum Time Efficiency for BPCs. (NOT IMPLEMENTED \u2014 accepted but ignored by the service; do not expose in clients)",
            "in": "query",
            "name": "max_te",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "minimum": 0,
                  "type": "integer"
                },
                {
                  "type": "null"
                }
              ],
              "description": "Maximum Time Efficiency for BPCs. (NOT IMPLEMENTED \u2014 accepted but ignored by the service; do not expose in clients)",
              "title": "Max Te"
            }
          },
          {
            "description": "List of region IDs to filter by.",
            "in": "query",
            "name": "region_ids",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "items": {
                    "type": "integer"
                  },
                  "type": "array"
                },
                {
                  "type": "null"
                }
              ],
              "description": "List of region IDs to filter by.",
              "title": "Region Ids"
            }
          },
          {
            "description": "List of solar system IDs to filter by.",
            "in": "query",
            "name": "system_ids",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "items": {
                    "type": "integer"
                  },
                  "type": "array"
                },
                {
                  "type": "null"
                }
              ],
              "description": "List of solar system IDs to filter by.",
              "title": "System Ids"
            }
          },
          {
            "description": "List of station IDs to filter by.",
            "in": "query",
            "name": "station_ids",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "items": {
                    "type": "integer"
                  },
                  "type": "array"
                },
                {
                  "type": "null"
                }
              ],
              "description": "List of station IDs to filter by.",
              "title": "Station Ids"
            }
          },
          {
            "description": "List of ship type IDs to filter by.",
            "in": "query",
            "name": "type_ids",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "items": {
                    "type": "integer"
                  },
                  "type": "array"
                },
                {
                  "type": "null"
                }
              ],
              "description": "List of ship type IDs to filter by.",
              "title": "Type Ids"
            }
          },
          {
            "description": "Filter for contracts containing blueprints (BPCs).",
            "in": "query",
            "name": "is_bpc",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "boolean"
                },
                {
                  "type": "null"
                }
              ],
              "description": "Filter for contracts containing blueprints (BPCs).",
              "title": "Is Bpc"
            }
          },
          {
            "description": "Filter for contracts flagged as ship contracts (contract-level flag).",
            "in": "query",
            "name": "is_ship_contract",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "boolean"
                },
                {
                  "type": "null"
                }
              ],
              "description": "Filter for contracts flagged as ship contracts (contract-level flag).",
              "title": "Is Ship Contract"
            }
          },
          {
            "description": "Page number.",
            "in": "query",
            "name": "page",
            "required": false,
            "schema": {
              "default": 1,
              "description": "Page number.",
              "minimum": 1,
              "title": "Page",
              "type": "integer"
            }
          },
          {
            "description": "Number of items per page.",
            "in": "query",
            "name": "size",
            "required": false,
            "schema": {
              "default": 50,
              "description": "Number of items per page.",
              "maximum": 100,
              "minimum": 1,
              "title": "Size",
              "type": "integer"
            }
          },
          {
            "description": "Field to sort by.",
            "in": "query",
            "name": "sort_by",
            "required": false,
            "schema": {
              "$ref": "#/components/schemas/SortableContractFields",
              "default": "date_issued",
              "description": "Field to sort by."
            }
          },
          {
            "description": "Sort direction.",
            "in": "query",
            "name": "sort_direction",
            "required": false,
            "schema": {
              "$ref": "#/components/schemas/SortDirection",
              "default": "desc",
              "description": "Sort direction."
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PaginatedResponse_ContractSchema_"
                }
              }
            },
            "description": "Successful Response"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            },
            "description": "Validation Error"
          }
        },
        "summary": "List Public Contracts",
        "tags": [
          "Contracts"
        ]
      }
    },
